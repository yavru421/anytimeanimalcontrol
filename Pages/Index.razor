@page "/"
@inject IJSRuntime JSRuntime

<PageTitle>Anytime Animal Control - Estimate Wizard</PageTitle>

<div class="aac-dashboard">
    <header class="aac-header">
        <h1>Anytime Animal Control</h1>
        <p class="subtitle">Estimate Compiler</p>
        <div class="contact-info" style="margin-top: 15px; font-size: 0.9rem; color: #AAA;">
            <span>📞 715-459-7412</span> | <span>👤 Mike</span> | <span>📱 TikTok: @MikeFlick3</span>
            <div style="margin-top: 5px; font-size: 0.8rem; color: #888;">
                Specializing in Removal of Bats, Squirrels, Raccoons, Skunks, Opossums, & More
            </div>
        </div>
    </header>

    <div class="aac-wizard">
        <div class="wizard-progress">
            <div class="progress-bar" style="width: @((CurrentStep * 25) + "%")"></div>
        </div>

        @if (CurrentStep == 1)
        {
            <div class="wizard-card slide-in">
                <h2>Client Information</h2>
                <div class="form-group floating">
                    <input id="clientName" @bind="clientName" placeholder=" " />
                    <label for="clientName">Client Name</label>
                </div>
                <div class="form-group floating">
                    <input id="clientAddress" @bind="clientAddress" placeholder=" " />
                    <label for="clientAddress">Address</label>
                </div>
                <div class="form-group floating">
                    <input id="clientEmail" type="email" @bind="clientEmail" placeholder=" " />
                    <label for="clientEmail">Email</label>
                </div>
            </div>
        }
        else if (CurrentStep == 2)
        {
            <div class="wizard-card slide-in">
                <h2>Services Calculator</h2>
                
                <div class="calc-row">
                    <div class="calc-label">
                        <label>Ridge Vent Screening (ft)</label>
                        <span class="rate-info">@($"${RidgeVentRate}/ft")</span>
                    </div>
                    <input type="number" min="0" @bind="ridgeVentFt" @bind:event="oninput" @onkeyup="CalculateTotal" @onchange="CalculateTotal" class="premium-input" />
                    <span class="row-total">@($"${RidgeVentTotal:F2}")</span>
                </div>

                <div class="calc-row">
                    <div class="calc-label">
                        <label>Soffit Returns (units)</label>
                        <span class="rate-info">@($"${SoffitReturnRate}/ea")</span>
                    </div>
                    <input type="number" min="0" @bind="soffitReturnsCount" @bind:event="oninput" @onkeyup="CalculateTotal" @onchange="CalculateTotal" class="premium-input" />
                    <span class="row-total">@($"${SoffitReturnTotal:F2}")</span>
                </div>

                <div class="calc-row">
                    <div class="calc-label">
                        <label>Wood Trim/Brick Sealing (ft)</label>
                        <span class="rate-info">@($"${SealingRate}/ft")</span>
                    </div>
                    <input type="number" min="0" @bind="sealingFt" @bind:event="oninput" @onkeyup="CalculateTotal" @onchange="CalculateTotal" class="premium-input" />
                    <span class="row-total">@($"${SealingTotal:F2}")</span>
                </div>

                <div class="total-banner">
                    <h3>Subtotal: <span class="grand-total">@($"${GrandTotal:F2}")</span></h3>
                </div>
            </div>
        }
        else if (CurrentStep == 3)
        {
            <div class="wizard-card slide-in">
                <h2>Project Notes & Location</h2>
                <div class="form-group">
                    <textarea @bind="projectNotes" rows="5" class="premium-textarea" placeholder="Enter specific instructions, access details, or wildlife observations here..."></textarea>
                </div>
                <div class="location-notice">
                    <p>📍 Location data will be recorded upon generation for legal verification.</p>
                </div>
            </div>
        }
        else if (CurrentStep == 4)
        {
            <div class="wizard-card slide-in final-card">
                <h2>Authorization</h2>
                <div class="grand-total-display">
                    <h3>Final Estimate: @($"${GrandTotal:F2}")</h3>
                </div>
                <p class="sig-instruction">Please sign below to authorize the quoted work.</p>
                <div class="signature-container">
                    <canvas id="signatureCanvas" width="400" height="200"></canvas>
                </div>
                <button class="btn btn-outline" @onclick="ClearSignature">Clear Signature</button>
            </div>
        }

        <div class="wizard-actions">
            @if (CurrentStep > 1)
            {
                <button class="btn btn-secondary" @onclick="PrevStep">← Back</button>
            }
            @if (CurrentStep < TotalSteps)
            {
                <button class="btn btn-primary next-btn" @onclick="NextStep">Next →</button>
            }
            @if (CurrentStep == TotalSteps)
            {
                <button class="btn btn-action glow" @onclick="GenerateQuote">COMPILE PRICE FOR THIS JOB?</button>
            }
        </div>
    </div>
</div>
